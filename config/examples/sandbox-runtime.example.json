  "broker": {
    "mode": "live",
    "broker_plugin": "okx_broker",
    "account_id": "SANDBOX_ACCOUNT_PLACEHOLDER",
    "order_log_path": "logs/sandbox/orders.jsonl",
    "settings": {
      "venue": "okx",
      "sandbox": true,
      "testnet": true,
      "td_mode": "cash",
      "target_currency": "base_ccy",
      "api_key_env": "OKX_SANDBOX_API_KEY",
      "api_secret_env": "OKX_SANDBOX_API_SECRET",
      "api_passphrase_env": "OKX_SANDBOX_API_PASSPHRASE",
      "allow_live_orders": false,
      "dry_run": true,
      "require_manual_preflight": true,
      "credential_mode": "env"
    }
  },
  "environment": {
    "tier": "exchange_sandbox",
    "external_exchange_access": true,
    "private_api_read": true,
    "live_order_submission": false,
    "dry_run": true,
    "requires_proxy": true,
    "requires_credentials": true,
    "requires_manual_preflight": true,
    "requires_human_approval": true,
    "tests_default_skipped": true,
    "credential_mode": "env",
    "metadata": {
      "sandbox_orders_disabled_by_default": true,
      "explicit_operator_authorization_required": true
