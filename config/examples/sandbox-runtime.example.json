  "logging": {
    "decision_log_path": "logs/sandbox/decisions.jsonl",
    "order_log_path": "logs/sandbox/orders.jsonl",
    "fill_log_path": "logs/sandbox/fills.jsonl",
    "pipeline_report_dir": "logs/sandbox/pipeline-runs"
