{
  "name": "sandbox-btc-usdt-okx-testnet",
  "source": "live",
  "markets": [
    {
      "symbol": "BTC-USDT",
      "timeframe": "1m",
      "asset_class": "crypto",
      "enabled": true,
      "provider": "okx_public",
      "metadata": {
        "venue": "okx",
        "instrument_type": "SPOT",
        "sandbox": true
      }
    }
  ],
  "strategies": [
    {
      "symbol": "BTC-USDT",
      "strategy": "ma_crossover",
      "route": "default",
      "version": "1.0",
      "parameters": {
        "fast_window": 5,
        "slow_window": 21,
        "strategy_id": "sandbox_btc_ma_guarded"
      }
    }
  ],
  "risk": {
    "risk_plugin": "default",
    "kill_switch_enabled": true,
    "daily_loss_limit_pct": 0.02,
    "consecutive_loss_limit": 2,
    "api_failure_rate_limit": 0.15,
    "max_position_size": 0.05,
    "max_drawdown": 0.04,
    "per_symbol_limits": {
      "BTC-USDT": 0.05
